# Instagram Mode: "instagrapi" or "graph_api"
IG_MODE=instagrapi

# Instagrapi mode (regular account)
IG_USERNAME=
IG_PASSWORD=
IG_SESSION_FILE=session.json
POLL_INTERVAL=20

# Graph API mode (business account)
INSTAGRAM_PAGE_ACCESS_TOKEN=
INSTAGRAM_APP_SECRET=
INSTAGRAM_VERIFY_TOKEN=
INSTAGRAM_ACCOUNT_ID=

# AI
ANTHROPIC_API_KEY=
AI_PROVIDER=claude
AI_MODEL=claude-sonnet-4-20250514

# App
REPLY_DELAY_SECONDS=3
LOG_LEVEL=INFO

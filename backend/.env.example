# ============================================
# Instagram Bot 配置文件
# 复制此文件为 .env 并填入你的值
# ============================================

# Instagram 模式: "instagrapi" (非官方轮询) 或 "graph_api" (官方Webhook)
IG_MODE=graph_api

# ---- Instagrapi 模式 (普通账号) ----
IG_USERNAME=
IG_PASSWORD=
IG_SESSION_FILE=session.json
POLL_INTERVAL=60

# ---- Graph API 模式 (商业账号, 推荐) ----
# 从 Facebook Developer Console 获取
INSTAGRAM_PAGE_ACCESS_TOKEN=你的长期PageAccessToken
INSTAGRAM_APP_SECRET=你的App密钥
INSTAGRAM_VERIFY_TOKEN=自定义验证字符串随便写一个比如mysecrettoken123
INSTAGRAM_ACCOUNT_ID=你的Instagram业务账号ID

# ---- AI 配置 ----
ANTHROPIC_API_KEY=sk-ant-api03-你的密钥
AI_PROVIDER=claude
AI_MODEL=claude-sonnet-4-20250514

# ---- 应用配置 ----
REPLY_DELAY_SECONDS=3
LOG_LEVEL=INFO

# InstaBot backend environment template.
# Copy to backend/.env and fill in real values. Never commit .env.

# ─── Instagram client mode ────────────────────────────────────────────
# graph_api: production mode using Meta's webhooks (recommended).
# instagrapi: unofficial polling client; useful for accounts without
#             Business API access. NOT recommended for production.
IG_MODE=graph_api

# ─── Graph API mode (used when IG_MODE=graph_api) ─────────────────────
# Page Access Token from Meta Graph API Explorer. Long-lived tokens
# expire after 60 days; password changes on the IG account invalidate
# the token immediately. See docs/OPERATIONS.md for the rotation
# procedure.
INSTAGRAM_PAGE_ACCESS_TOKEN=

# Used to verify webhook signatures (X-Hub-Signature-256 header).
# Find under: Meta App → Settings → Basic → App Secret.
INSTAGRAM_APP_SECRET=

# Random string you make up; Meta will echo it back during webhook
# subscription. Must match what you put in the Meta dashboard webhook
# config.
INSTAGRAM_VERIFY_TOKEN=change-me-to-any-random-string

# Optional. Auto-detected from /me; set explicitly only if you need to
# override the business account that owns the token.
INSTAGRAM_ACCOUNT_ID=

# ─── instagrapi mode (used when IG_MODE=instagrapi) ───────────────────
IG_USERNAME=
IG_PASSWORD=
IG_SESSION_FILE=session.json
POLL_INTERVAL=20

# ─── AI providers ─────────────────────────────────────────────────────
# Fill in whichever provider(s) you'll use. The Settings UI lets you
# switch models at runtime; the provider is auto-detected from the
# model id (claude-* → Anthropic, gpt-* / o-* → OpenAI, gemini-* → Google).
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENAI_BASE_URL=
GOOGLE_API_KEY=

# Default provider/model on first start, before any UI override.
AI_PROVIDER=claude
AI_MODEL=claude-sonnet-4-20250514

# ─── Auth ─────────────────────────────────────────────────────────────
# Password for the manager dashboard login.
ADMIN_PASSWORD=change-me

# Random secret used to sign JWT auth tokens. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
AUTH_SECRET_KEY=change-me-to-a-random-string

# ─── App behaviour ────────────────────────────────────────────────────
# Default delay (seconds) before sending an auto-reply, to feel
# human-paced. Overridable from Settings UI.
REPLY_DELAY_SECONDS=3

# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
